# ============================================================
# 复制为 .env 后填写。留空则用离线 fallback（哈希向量+拼接答复）。
# 注意：本项目 chat 与 embedding 共用同一个 base_url/key，
#       所以要选一个「同时提供对话模型 + embedding 模型」的厂商。
# ============================================================

# ---------- 方案A：硅基流动 SiliconFlow（推荐，一个 key 搞定两者）----------
OPENAI_API_KEY=sk-你的硅基流动key
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
CHAT_MODEL=Qwen/Qwen2.5-7B-Instruct
EMBEDDING_MODEL=BAAI/bge-m3

# ---------- 方案B：阿里百炼 DashScope（OpenAI 兼容模式）----------
# OPENAI_API_KEY=sk-你的百炼key
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# CHAT_MODEL=qwen-plus
# EMBEDDING_MODEL=text-embedding-v3

# ---------- 方案C：OpenAI 官方 ----------
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# CHAT_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small

# ---------- 检索参数 ----------
TOP_K=5
CHUNK_SIZE=512
CHUNK_OVERLAP=64
MAX_ITERATIONS=3

# ---------- 可选：真实向量库 / 缓存 / MCP（不填则回退内存/本地）----------
# VECTOR_BACKEND=qdrant
# QDRANT_URL=http://localhost:6333
# REDIS_URL=redis://localhost:6379/0
# USE_MCP=1

# ---------- 记忆层（不填全部走默认；持久记忆需配 Qdrant，会话态需配 Redis）----------
# MEM_ENABLED=1                  # 0 关闭记忆层
# MEM_COLLECTION=agentdesk_memory  # 记忆专用 Qdrant collection（独立于知识库）
# MEM_SHORT_WINDOW_K=2           # 短期记忆保留的最近轮数
# MEM_SUMMARIZE_EVERY_N=3        # 每 N 轮触发一次滚动摘要
# MEM_LONG_TOP_K=3               # 每轮召回的长期记忆条数
# MEM_DEDUP_THRESHOLD=0.92       # 相似度≥此值视为同一条（更新不新增）
# MEM_CONFLICT_THRESHOLD=0.80    # (此值,dedup) 区间且同类事实→冲突覆盖（留审计）
# MEM_EVENT_TTL_DAYS=30          # event 类记忆过期天数
# MEM_MAX_PER_USER=500           # 单用户记忆上限，超则 LRU 淘汰
# TRACE_LOG=1                    # 每轮 trace 落盘到 eval/reports/traces.jsonl；设 0 关闭
