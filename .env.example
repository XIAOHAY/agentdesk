# ============================================================
# 复制为 .env 后填写。留空则用离线 fallback（哈希向量+拼接答复）。
# 注意：本项目 chat 与 embedding 共用同一个 base_url/key，
#       所以要选一个「同时提供对话模型 + embedding 模型」的厂商。
# ============================================================

# ---------- 方案A：硅基流动 SiliconFlow（推荐，一个 key 搞定两者）----------
OPENAI_API_KEY=sk-你的硅基流动key
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
CHAT_MODEL=Qwen/Qwen2.5-7B-Instruct
EMBEDDING_MODEL=BAAI/bge-m3

# ---------- 方案B：阿里百炼 DashScope（OpenAI 兼容模式）----------
# OPENAI_API_KEY=sk-你的百炼key
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# CHAT_MODEL=qwen-plus
# EMBEDDING_MODEL=text-embedding-v3

# ---------- 方案C：OpenAI 官方 ----------
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# CHAT_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small

# ---------- 检索参数 ----------
TOP_K=5
CHUNK_SIZE=512
CHUNK_OVERLAP=64
MAX_ITERATIONS=3

# ---------- 可选：真实向量库 / 缓存 / MCP（不填则回退内存/本地）----------
# VECTOR_BACKEND=qdrant
# QDRANT_URL=http://localhost:6333
# REDIS_URL=redis://localhost:6379/0
# USE_MCP=1
