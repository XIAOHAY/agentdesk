# 复制为 .streamlit/secrets.toml（本地），或在 Streamlit Cloud 的
# App settings → Secrets 里粘贴以下内容来启用「真实大模型」。
# 全部留空 / 不配置 → 自动走离线 fallback，无需任何 key 也能跑。

# OPENAI_API_KEY = "sk-你的key"
# OPENAI_BASE_URL = "https://api.siliconflow.cn/v1"
# CHAT_MODEL = "Qwen/Qwen2.5-7B-Instruct"
# EMBEDDING_MODEL = "BAAI/bge-m3"
# TOP_K = "5"
# MAX_ITERATIONS = "3"
